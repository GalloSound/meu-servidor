NPM_DB_ROOT_PASSWORD=troque-esta-senha-root
NPM_DB_NAME=npm
NPM_DB_USER=npm
NPM_DB_PASSWORD=troque-esta-senha-db

# Portas recomendadas:
# - Local: evitar conflito com phpMyAdmin (8080) e PHP global (8082).
# - VPS: normalmente usar 80/443/81.
NPM_HTTP_PORT=8084
NPM_HTTPS_PORT=4443
NPM_ADMIN_PORT=8081
